---
import { siteConfig } from "../config";
---

<section id="trayectoria" class="py-16 sm:py-20 bg-[var(--color-surface)]">
  <div class="max-w-4xl mx-auto px-5">
    <div class="text-center mb-10 reveal">
      <h2 class="text-2xl sm:text-3xl font-bold text-white">Trayectoria</h2>
      <div class="flex items-center gap-3 mt-3 justify-center">
        <div class="h-px w-8 bg-[var(--color-accent)]"></div>
        <svg width="14" height="14" viewBox="0 0 24 24" fill="var(--color-accent)">
          <path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/>
        </svg>
        <div class="h-px w-8 bg-[var(--color-accent)]"></div>
      </div>
    </div>

    <!-- Timeline -->
    <div class="relative">
      <!-- Vertical line -->
      <div class="absolute left-4 sm:left-1/2 top-0 bottom-0 w-px bg-[var(--color-primary-light)]/30 sm:-translate-x-px"></div>

      <div class="space-y-8">
        {siteConfig.trayectoria.map((item, i) => (
          <div class={`reveal stagger-${Math.min((i % 6) + 1, 6)} relative flex items-start gap-6 ${i % 2 === 0 ? 'sm:flex-row' : 'sm:flex-row-reverse'}`}>
            <!-- Dot -->
            <div class="absolute left-4 sm:left-1/2 w-3 h-3 rounded-full bg-[var(--color-accent)] border-2 border-[var(--color-primary-dark)] -translate-x-1/2 mt-1.5 z-10 timeline-dot" style={`animation-delay: ${i * 0.1}s`}></div>

            <!-- Content -->
            <div class={`ml-10 sm:ml-0 sm:w-[calc(50%-2rem)] ${i % 2 === 0 ? 'sm:text-right sm:pr-8' : 'sm:text-left sm:pl-8'}`}>
              <span class="font-stats text-sm font-bold text-[var(--color-accent)]">{item.año}</span>
              <h3 class="text-white font-bold mt-0.5">{item.titulo}</h3>
              <p class="text-sm text-slate-400 font-['Source_Sans_3']">{item.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
