---
import { siteConfig } from "../config";
---

<section id="experiencia" class="py-16 sm:py-20 bg-[var(--color-primary-dark)]">
  <div class="max-w-5xl mx-auto px-5">
    <div class="text-center mb-10 reveal">
      <h2 class="text-2xl sm:text-3xl font-bold text-white">Experiencia Laboral</h2>
      <div class="flex items-center gap-3 mt-3 justify-center">
        <div class="h-px w-8 bg-[var(--color-accent)]"></div>
        <svg width="14" height="14" viewBox="0 0 24 24" fill="var(--color-accent)">
          <path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/>
        </svg>
        <div class="h-px w-8 bg-[var(--color-accent)]"></div>
      </div>
    </div>

    <div class="space-y-4">
      {siteConfig.experiencia.map((exp, i) => (
        <div class={`reveal stagger-${Math.min(i + 1, 6)} card-hover bg-[var(--color-surface-light)] border rounded-xl p-5 sm:p-6 ${exp.destacado ? 'border-[var(--color-accent)]/40' : 'border-[var(--color-primary-light)]/20'}`}>
          <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-2">
            <div class="flex-1">
              <div class="flex items-center gap-2 flex-wrap">
                <h3 class="text-lg font-bold text-white">{exp.institucion}</h3>
                {exp.duracion && (
                  <span class="bg-[var(--color-accent)]/10 text-[var(--color-accent)] text-xs font-semibold px-2.5 py-0.5 rounded-full" style="font-family: 'Source Sans 3', sans-serif;">
                    {exp.duracion}
                  </span>
                )}
              </div>
              <p class="text-[var(--color-accent)] mt-1" style="font-family: 'Source Sans 3', sans-serif;">{exp.cargo}</p>
              {exp.detalle && (
                <p class="text-sm text-slate-400 mt-2" style="font-family: 'Source Sans 3', sans-serif;">{exp.detalle}</p>
              )}
            </div>
            <span class="font-stats text-sm text-slate-400 whitespace-nowrap">{exp.periodo}</span>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
