---
import { siteConfig } from "../config";
---

<section id="alcance" class="py-16 sm:py-20 bg-[var(--color-surface)]">
  <div class="max-w-5xl mx-auto px-5">
    <div class="text-center mb-10 reveal">
      <h2 class="text-2xl sm:text-3xl font-bold text-white">Formación Internacional</h2>
      <div class="flex items-center gap-3 mt-3 justify-center">
        <div class="h-px w-8 bg-[var(--color-accent)]"></div>
        <svg width="14" height="14" viewBox="0 0 24 24" fill="var(--color-accent)">
          <path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/>
        </svg>
        <div class="h-px w-8 bg-[var(--color-accent)]"></div>
      </div>
      <p class="text-slate-400 font-['Source_Sans_3'] mt-3 text-sm">
        Formación y experiencia en 5 países
      </p>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
      {siteConfig.alcanceInternacional.map((pais, i) => (
        <div class={`reveal stagger-${Math.min(i + 1, 6)} card-hover badge-shine bg-[var(--color-surface-light)] border border-[var(--color-primary-light)]/20 rounded-xl p-5`}>
          <div class="flex items-center gap-3 mb-3">
            <span class="text-3xl">{pais.bandera}</span>
            <h3 class="text-lg font-bold text-white">{pais.pais}</h3>
          </div>
          <div class="space-y-1.5">
            {pais.instituciones.map((inst) => (
              <div class="flex items-start gap-2">
                <div class="w-1.5 h-1.5 rounded-full bg-[var(--color-accent)] mt-1.5 shrink-0"></div>
                <span class="text-sm text-slate-300 font-['Source_Sans_3']">{inst}</span>
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
