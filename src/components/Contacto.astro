---
import { siteConfig } from "../config";
---

<section id="contacto" class="py-16 sm:py-20 bg-[var(--color-surface)]">
  <div class="max-w-3xl mx-auto px-5 text-center">
    <div class="reveal">
      <h2 class="text-2xl sm:text-3xl font-bold text-white">Contacto</h2>
      <div class="flex items-center gap-3 mt-3 justify-center">
        <div class="h-px w-8 bg-[var(--color-accent)]"></div>
        <svg width="14" height="14" viewBox="0 0 24 24" fill="var(--color-accent)">
          <path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/>
        </svg>
        <div class="h-px w-8 bg-[var(--color-accent)]"></div>
      </div>
    </div>

    <div class="reveal stagger-1 mt-8 space-y-4">
      <!-- Email -->
      <a href={`mailto:${siteConfig.social.email}`} class="flex items-center justify-center gap-3 text-slate-300 hover:text-[var(--color-accent)] transition-colors font-['Source_Sans_3']">
        <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
          <path d="M22 6l-10 7L2 6"/>
        </svg>
        {siteConfig.social.email}
      </a>

      <!-- Phone -->
      <a href={`tel:+${siteConfig.social.whatsapp}`} class="flex items-center justify-center gap-3 text-slate-300 hover:text-[var(--color-accent)] transition-colors font-['Source_Sans_3']">
        <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/>
        </svg>
        {siteConfig.contacto.telefono}
      </a>

      <!-- Location -->
      <div class="flex items-center justify-center gap-3 text-slate-400 font-['Source_Sans_3']">
        <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/>
          <circle cx="12" cy="10" r="3"/>
        </svg>
        {siteConfig.contacto.ubicacion}
      </div>
    </div>

    <!-- Social Links -->
    <div class="reveal stagger-2 flex justify-center gap-4 mt-8">
      {siteConfig.social.linkedin && (
        <a href={siteConfig.social.linkedin} target="_blank" rel="noopener noreferrer" class="w-10 h-10 rounded-full bg-[var(--color-surface-light)] border border-[var(--color-primary-light)]/20 flex items-center justify-center text-slate-400 hover:text-[var(--color-accent)] hover:border-[var(--color-accent)]/40 transition-colors">
          <svg width="18" height="18" fill="currentColor" viewBox="0 0 24 24">
            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
          </svg>
        </a>
      )}

      {siteConfig.social.whatsapp && (
        <a href={`https://wa.me/${siteConfig.social.whatsapp}`} target="_blank" rel="noopener noreferrer" class="w-10 h-10 rounded-full bg-[var(--color-surface-light)] border border-[var(--color-primary-light)]/20 flex items-center justify-center text-slate-400 hover:text-[var(--color-accent)] hover:border-[var(--color-accent)]/40 transition-colors">
          <svg width="18" height="18" fill="currentColor" viewBox="0 0 24 24">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
        </a>
      )}
    </div>

    <!-- CTA -->
    <div class="reveal stagger-3 mt-8">
      <a href={`https://wa.me/${siteConfig.social.whatsapp}?text=Hola%20Dr.%20Butler,%20quisiera%20agendar%20una%20consulta`}
         target="_blank" rel="noopener noreferrer"
         class="btn-hover inline-flex items-center gap-2 bg-[var(--color-accent)] text-[var(--color-primary-dark)] font-semibold font-['Source_Sans_3'] px-8 py-3.5 rounded-full text-sm">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/>
        </svg>
        Agendar Consulta
      </a>
    </div>
  </div>
</section>
