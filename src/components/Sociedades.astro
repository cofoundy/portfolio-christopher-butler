---
import { siteConfig } from "../config";
---

<section id="sociedades" class="py-16 sm:py-20 bg-[var(--color-primary-dark)]">
  <div class="max-w-5xl mx-auto px-5">
    <div class="text-center mb-10 reveal">
      <h2 class="text-2xl sm:text-3xl font-bold text-white">Miembro de</h2>
      <div class="flex items-center gap-3 mt-3 justify-center">
        <div class="h-px w-8 bg-[var(--color-accent)]"></div>
        <svg width="14" height="14" viewBox="0 0 24 24" fill="var(--color-accent)">
          <path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/>
        </svg>
        <div class="h-px w-8 bg-[var(--color-accent)]"></div>
      </div>
    </div>

    <div class="grid grid-cols-2 sm:grid-cols-3 gap-4">
      {siteConfig.sociedades.map((soc, i) => (
        <div class={`reveal stagger-${Math.min(i + 1, 6)} badge-shine group bg-[var(--color-surface-light)] border border-[var(--color-primary-light)]/20 rounded-xl p-5 text-center hover:border-[var(--color-accent)]/40 transition-colors`}>
          <!-- Shield icon -->
          <div class="w-12 h-12 mx-auto mb-3 rounded-full bg-[var(--color-accent)]/10 flex items-center justify-center">
            <span class="font-stats text-lg font-bold text-[var(--color-accent)]">{soc.sigla}</span>
          </div>
          <p class="text-xs text-slate-300 font-['Source_Sans_3'] leading-snug">{soc.nombre}</p>
          <p class="text-xs text-slate-500 font-['Source_Sans_3'] mt-1">{soc.tipo}</p>
        </div>
      ))}
    </div>
  </div>
</section>
