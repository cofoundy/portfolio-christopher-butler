---
import { siteConfig } from "../config";
---

<section id="sobre-mi" class="py-16 sm:py-20 bg-[var(--color-primary-dark)]">
  <div class="max-w-5xl mx-auto px-5">
    <div class="text-center mb-10 reveal">
      <h2 class="text-2xl sm:text-3xl font-bold text-white">Sobre Mí</h2>
      <div class="flex items-center gap-3 mt-3 justify-center">
        <div class="h-px w-8 bg-[var(--color-accent)]"></div>
        <svg width="14" height="14" viewBox="0 0 24 24" fill="var(--color-accent)">
          <path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/>
        </svg>
        <div class="h-px w-8 bg-[var(--color-accent)]"></div>
      </div>
    </div>

    <div class="grid md:grid-cols-5 gap-8 items-start">
      <!-- Narrative (3 cols) -->
      <div class="md:col-span-3 reveal">
        <p class="text-slate-300 font-['Source_Sans_3'] text-base sm:text-lg leading-relaxed">
          {siteConfig.aboutMe}
        </p>

        <!-- Quote -->
        <blockquote class="mt-6 border-l-2 border-[var(--color-accent)] pl-4">
          <p class="text-[var(--color-accent)] italic font-['DM_Serif_Display'] text-lg">
            "La cardiología no es solo ciencia — es la vocación de cuidar lo que nos mantiene vivos."
          </p>
        </blockquote>
      </div>

      <!-- Especialidades (2 cols) -->
      <div class="md:col-span-2 reveal stagger-2">
        <h3 class="text-sm font-['Source_Sans_3'] font-semibold uppercase tracking-widest text-[var(--color-accent)] mb-4">
          Especialidades
        </h3>
        <div class="space-y-3">
          {siteConfig.especialidades.map((esp) => (
            <div class="flex items-center gap-3 group">
              <div class="w-2 h-2 rounded-full bg-[var(--color-accent)] group-hover:scale-125 transition-transform"></div>
              <span class="text-slate-200 font-['Source_Sans_3']">{esp}</span>
            </div>
          ))}
        </div>

        <!-- Docencia -->
        <h3 class="text-sm font-['Source_Sans_3'] font-semibold uppercase tracking-widest text-[var(--color-accent)] mb-4 mt-8">
          Docencia Universitaria
        </h3>
        <div class="space-y-2">
          {siteConfig.docencia.map((doc) => (
            <div class="text-sm font-['Source_Sans_3']">
              <span class="text-slate-200">{doc.universidad}</span>
              <span class="text-slate-400 block">{doc.area} · {doc.periodo}</span>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>
