---
import { siteConfig } from "../config";
---

<section id="en-medios" class="py-16 sm:py-20 bg-[var(--color-surface)]">
  <div class="max-w-3xl mx-auto px-5">
    <div class="text-center mb-10 reveal">
      <h2 class="text-2xl sm:text-3xl font-bold text-white">En Medios</h2>
      <div class="flex items-center gap-3 mt-3 justify-center">
        <div class="h-px w-8 bg-[var(--color-accent)]"></div>
        <svg width="14" height="14" viewBox="0 0 24 24" fill="var(--color-accent)">
          <path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/>
        </svg>
        <div class="h-px w-8 bg-[var(--color-accent)]"></div>
      </div>
    </div>

    <div class="grid sm:grid-cols-2 gap-6 items-start">
      <!-- TikTok SANNA -->
      <div class="reveal stagger-1">
        <div class="rounded-xl overflow-hidden" style="aspect-ratio: 9/16;">
          <iframe
            src="https://www.tiktok.com/embed/v2/7460539344974138629"
            style="width: 100%; height: 100%; border: none;"
            allowfullscreen
            allow="encrypted-media"
            loading="lazy"
          ></iframe>
        </div>
        <div class="mt-3">
          <span class="bg-[var(--color-accent)]/10 text-[var(--color-accent)] text-xs font-semibold px-2.5 py-0.5 rounded-full" style="font-family: 'Source Sans 3', sans-serif;">
            SANNA Salud · TikTok
          </span>
          <p class="text-sm text-slate-300 mt-2" style="font-family: 'Source Sans 3', sans-serif;">
            Infarto en mujeres: factores de riesgo y señales de alerta
          </p>
        </div>
      </div>

      <!-- Facebook Reel -->
      <div class="reveal stagger-2">
        <div class="rounded-xl overflow-hidden" style="aspect-ratio: 9/16;">
          <iframe
            src="https://www.facebook.com/plugins/video.php?height=476&href=https%3A%2F%2Fwww.facebook.com%2Freel%2F762959882168549%2F&show_text=false&width=267&t=0"
            style="width: 100%; height: 100%; border: none; overflow: hidden;"
            scrolling="no"
            allowfullscreen
            allow="autoplay; clipboard-write; encrypted-media; picture-in-picture; web-share"
            loading="lazy"
          ></iframe>
        </div>
        <div class="mt-3">
          <span class="bg-[var(--color-accent)]/10 text-[var(--color-accent)] text-xs font-semibold px-2.5 py-0.5 rounded-full" style="font-family: 'Source Sans 3', sans-serif;">
            Facebook
          </span>
          <p class="text-sm text-slate-300 mt-2" style="font-family: 'Source Sans 3', sans-serif;">
            Día de la Cardiología Peruana — Hospital de Lima Este Vitarte
          </p>
        </div>
      </div>
    </div>
  </div>
</section>
