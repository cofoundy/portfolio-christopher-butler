---
import Nav from "../components/Nav.astro";
import Hero from "../components/Hero.astro";
import DondeAtiendo from "../components/DondeAtiendo.astro";
import Experiencia from "../components/Experiencia.astro";
import SobreMi from "../components/SobreMi.astro";
import AlcanceInternacional from "../components/AlcanceInternacional.astro";
import Sociedades from "../components/Sociedades.astro";
import Trayectoria from "../components/Trayectoria.astro";
import EnMedios from "../components/EnMedios.astro";
import Investigacion from "../components/Investigacion.astro";
import Contacto from "../components/Contacto.astro";
import Footer from "../components/Footer.astro";
import { siteConfig } from "../config";
import "../styles/global.css";

const base = import.meta.env.BASE_URL?.replace(/\/$/, '') || '';
---

<html lang="es" style={`--color-primary-dark:${siteConfig.colors.primaryDark};--color-primary:${siteConfig.colors.primary};--color-primary-light:${siteConfig.colors.primaryLight};--color-accent:${siteConfig.colors.accent};--color-surface:${siteConfig.colors.surface};--color-surface-light:${siteConfig.colors.surfaceLight}`}>
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href={`${base}/favicon.svg`} />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={siteConfig.description} />

    <!-- SEO -->
    <meta name="keywords" content="cardiólogo Lima, Dr Christopher Butler, cardiólogo SANNA, cardiólogo San Borja, ecocardiografía, insuficiencia cardíaca, hipertensión arterial, médico cardiólogo Perú, Hospital Lima Este Vitarte" />
    <meta name="author" content="Dr. Christopher Oskar Butler Vallejo" />
    <link rel="canonical" href="https://drcbutler.com/" />

    <!-- Open Graph -->
    <meta property="og:title" content={`${siteConfig.name} — ${siteConfig.title}`} />
    <meta property="og:description" content={siteConfig.description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://drcbutler.com/" />
    <meta property="og:image" content="https://drcbutler.com/og.jpg" />
    <meta property="og:locale" content="es_PE" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={`${siteConfig.name} — ${siteConfig.title}`} />
    <meta name="twitter:description" content={siteConfig.description} />
    <meta name="twitter:image" content="https://drcbutler.com/og.jpg" />

    <!-- Schema.org JSON-LD: Physician -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Physician",
      "name": "Dr. Christopher Oskar Butler Vallejo",
      "jobTitle": "Médico Cardiólogo",
      "description": siteConfig.description,
      "url": "https://drcbutler.com/",
      "image": "https://drcbutler.com/og.jpg",
      "telephone": "+51999434491",
      "email": "chrisbutler75@yahoo.com",
      "address": {
        "@type": "PostalAddress",
        "addressLocality": "San Borja",
        "addressRegion": "Lima",
        "addressCountry": "PE"
      },
      "medicalSpecialty": ["Cardiology", "Echocardiography"],
      "memberOf": [
        { "@type": "Organization", "name": "European Society of Cardiology" },
        { "@type": "Organization", "name": "Heart Failure Association (ESC)" },
        { "@type": "Organization", "name": "Sociedad Argentina de Cardiología" },
        { "@type": "Organization", "name": "Sociedad Peruana de Cardiología" }
      ],
      "worksFor": [
        { "@type": "Hospital", "name": "Clínica SANNA" },
        { "@type": "Hospital", "name": "Hospital de Lima Este - Vitarte" }
      ],
      "alumniOf": [
        { "@type": "CollegeOrUniversity", "name": "Universidad de San Martín de Porres" },
        { "@type": "CollegeOrUniversity", "name": "Universidad Nacional Federico Villarreal" }
      ],
      "sameAs": [
        "https://www.linkedin.com/in/christopher-butler-4ab382175/"
      ]
    })} />

    <!-- Fonts: DM Serif Display + Source Sans 3 + Space Grotesk -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=Source+Sans+3:wght@300;400;500;600;700&family=Space+Grotesk:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />

    <title>{siteConfig.name} — {siteConfig.title}</title>
  </head>
  <body>
    <Nav />
    <main>
      <Hero />
      <DondeAtiendo />
      <Experiencia />
      <SobreMi />
      <AlcanceInternacional />
      <Sociedades />
      <Trayectoria />
      <EnMedios />
      <Investigacion />
      <Contacto />
    </main>
    <Footer />

    <!-- Scroll Reveal Script -->
    <script>
      const observerOptions = {
        root: null,
        rootMargin: '0px 0px -10% 0px',
        threshold: 0.1
      };

      const revealOnScroll = (entries: IntersectionObserverEntry[], observer: IntersectionObserver) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            entry.target.classList.add('revealed');
            observer.unobserve(entry.target);
          }
        });
      };

      const observer = new IntersectionObserver(revealOnScroll, observerOptions);

      document.querySelectorAll('.reveal, .reveal-left, .reveal-scale').forEach(el => {
        observer.observe(el);
      });
    </script>
  </body>
</html>
